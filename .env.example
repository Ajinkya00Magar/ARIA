# ──────────────────────────────────────────────────────────────────────────────
# IBM Coding Agent — Environment Variables
# 1. Copy this file:  cp .env.example .env
# 2. Fill in the necessary values
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
NEXT_PUBLIC_API_URL=https://your-vercel-project-url.vercel.app/api
ALLOWED_ORIGINS=http://localhost:3000, https://your-vercel-project-url.vercel.app

# ── Storage ──────────────────────────────────────────────────────────────────
# No database required. Chat history is stored per-project inside each opened
# folder under `.aria/`, and app settings / recent folders live in the OS
# user-data directory. Nothing else to configure here.

# ── IBM Orchestrate Agent (Preferred) ────────────────────────────────────────
# Required if using Orchestrate: Add your endpoint URL and API key
IBM_ORCHESTRATE_URL=https://api.us-south.watson-orchestrate.cloud.ibm.com/instances/YOUR_INSTANCE_ID/v1/chat
IBM_ORCHESTRATE_API_KEY=your-ibm-cloud-api-key-here

# ── Cloud Proxy (For Local Desktop Bundle) ───────────────────────────────────
# Point this to your Vercel deployment URL where the Cloud API is running.
# Example: https://your-project.vercel.app/api/agent/run
CLOUD_PROXY_URL=
# ── IBM watsonx.ai (Required by schema, can use dummy values) ────────────────
# The system requires these variables to be present, but if you are using 
# IBM_ORCHESTRATE_URL above, these will be completely ignored.
IBM_CLOUD_API_KEY=dummy_value_ignored
IBM_PROJECT_ID=dummy_value_ignored
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com
IBM_REGION=us-south
IBM_MODEL_ID=GPT-OSS 120B — OpenAI (via Groq)
IBM_GRANITE_MODEL=GPT-OSS 120B — OpenAI (via Groq)

# ── Supabase (Required for Auth and Usage Tracking) ──────────────────────────
# Replace with your project URL and Anon Key from your Supabase dashboard
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
