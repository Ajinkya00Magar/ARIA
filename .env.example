# ─────────────────────────────────────────────────────────────────────────────
# ARIA — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
NEXTAUTH_URL=http://localhost:3000
API_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (local development)
DATABASE_URL=file:./local.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/aria_db

# ── Security ──────────────────────────────────────────────────────────────────
# Generate strong secrets: openssl rand -hex 32
JWT_SECRET=replace_with_a_secret_at_least_32_characters_long
JWT_REFRESH_SECRET=replace_with_a_different_secret_at_least_32_chars

# ── IBM watsonx Orchestrate (PRIMARY AGENT) ───────────────────────────────────
# Set this to use IBM Orchestrate as the agent intelligence layer
IBM_ORCHESTRATE_URL=https://api.us-south.watson-orchestrate.cloud.ibm.com/instances/YOUR_INSTANCE_ID/v1/orchestrate/YOUR_AGENT_ID/chat/completions
IBM_ORCHESTRATE_API_KEY=your_ibm_cloud_api_key_here

# Optional: Pre-acquired bearer token (auto-refreshed if not set)
# IBM_ORCHESTRATE_BEARER_TOKEN=

# ── IBM watsonx.ai (Fallback model + embeddings) ──────────────────────────────
IBM_CLOUD_API_KEY=your_ibm_cloud_api_key_here
IBM_PROJECT_ID=your_watsonx_project_id
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com
IBM_REGION=us-south
IBM_MODEL_ID=ibm/granite-34b-code-instruct

# ── Workspace Storage ─────────────────────────────────────────────────────────
# Where workspace files are stored on the server
WORKSPACE_ROOT=/tmp/aria-workspaces

# ── OAuth Providers (optional) ────────────────────────────────────────────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── IBM Object Storage (optional) ─────────────────────────────────────────────
# IBM_OBJECT_STORAGE_ENDPOINT=
# IBM_OBJECT_STORAGE_API_KEY=
# IBM_BUCKET=

# ── Frontend ──────────────────────────────────────────────────────────────────
# apps/web/.env.local:
# NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
