{
  "name": "@ibm-agent/desktop",
  "version": "1.0.0",
  "description": "ARIA Desktop IDE",
  "author": "IBM",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prebuild": "node copy-assets.js",
    "build": "electron-builder --windows"
  },
  "build": {
    "appId": "com.ibm.agent.desktop",
    "productName": "ARIA IDE",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "package.json",
      "bundle/**/*"
    ],
    "asarUnpack": [
      "node_modules/**/*.node"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg"
    }
  },
  "dependencies": {
    "@ibm-agent/api": "^1.0.0",
    "electron-serve": "^1.1.0",
    "wait-on": "^7.2.0"
  },
  "devDependencies": {
    "@ibm-agent/web": "*",
    "electron": "31.3.1",
    "electron-builder": "^24.13.3"
  }
}
