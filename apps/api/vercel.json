{
  "version": 2,
  "buildCommand": "cd ../.. && npm install && npx turbo run build --filter=@ibm-agent/api...",
  "outputDirectory": "dist",
  "functions": {
    "dist/index.js": {
      "runtime": "@vercel/node",
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "WORKSPACE_ROOT": "/tmp/ibm-agent-workspaces"
  }
}
