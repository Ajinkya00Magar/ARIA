{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "commonjs",
    "target": "ES2022",
    "lib": ["ES2022"],
    "paths": {
      "@ibm-agent/types": ["../../packages/types/src"],
      "@ibm-agent/shared": ["../../packages/shared/src"],
      "@ibm-agent/ai": ["../../packages/ai/src"],
      "@ibm-agent/tools": ["../../packages/tools/src"]
    }
  },
  "references": [
    { "path": "../../packages/types" },
    { "path": "../../packages/shared" },
    { "path": "../../packages/ai" },
    { "path": "../../packages/tools" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/db/seed.ts"]
}
