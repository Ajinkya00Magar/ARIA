# ──────────────────────────────────────────────────────────────────────────────
# apps/api — .env (local dev only, not committed)
# Copy this to apps/api/.env for running the API locally
# (turbo / npm workspaces will also pick up the root .env)
# ──────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
# No database required — chat history is stored per-project under `.aria/`,
# and app settings live in the OS user-data directory.
IBM_CLOUD_API_KEY=your_key
IBM_PROJECT_ID=your_project_id
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com
IBM_MODEL_ID=ibm/granite-34b-code-instruct
ALLOWED_ORIGINS=http://localhost:3000
WORKSPACE_ROOT=/tmp/ibm-agent-workspaces
LOG_LEVEL=info
